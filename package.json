{
  "name": "opod-admin",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "admin:check": "npm --workspace @ai-sns/admin run check",
    "admin:dev": "npm run start:dev",
    "build": "nest build",
    "format": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"prompts/**/*.ts\" \"packages/admin/**/*.{html,css,js,mjs}\"",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"prompts/**/*.ts\"",
    "db:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://ai_sns:ai_sns@localhost:5433/ai_sns} prisma generate",
    "schema:check": "node scripts/check-schema-sync.mjs",
    "start": "node --env-file=.env ./node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "node --env-file=.env ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:prod": "node dist/src/main.js",
    "test": "jest --watchman=false",
    "test:e2e": "jest --watchman=false --runInBand --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1076.0",
    "@aws-sdk/s3-request-presigner": "^3.1076.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    }
  }
}
